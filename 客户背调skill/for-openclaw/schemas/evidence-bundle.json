    "search_results": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "query": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "snippet": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "platform": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "page_snapshots": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "url": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "text": {
            "type": "string"
          },
          "source": {
            "type": "string"
          },
          "status": {
            "type": "string"
          }
        },
        "required": [
          "url"
        ]
      }
    },
    "search_runs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "stage": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "result_count": {
            "type": "integer"
          }
        }
      }
    },
    "errors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": true,
        "properties": {
          "stage": {
            "type": "string"
          },
          "provider": {
            "type": "string"
          },
          "query": {
            "type": "string"
          },
          "url": {
            "type": "string"
          },
          "message": {
            "type": "string"
          }
