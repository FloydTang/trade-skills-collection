{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClaw Lead Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["lead_candidates"],
  "properties": {
    "country_or_market": { "type": "string" },
    "operator_notes": { "type": "string" },
    "lead_candidates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object"
      }
    }
  }
}
