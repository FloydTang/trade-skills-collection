{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "OpenClaw Search Brief",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "product_or_offer",
    "target_market",
    "customer_type",
    "search_keywords"
  ],
  "properties": {
    "product_or_offer": { "type": "string" },
    "target_market": { "type": "string" },
    "customer_type": { "type": "string" },
    "search_keywords": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "must_include": {
      "type": "array",
      "items": { "type": "string" }
    },
    "exclude_terms": {
      "type": "array",
      "items": { "type": "string" }
    },
    "max_results": { "type": "integer" },
    "notes": { "type": "string" },
    "fixtures_json": { "type": "string" }
  }
}
